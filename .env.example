# 复制为 .env 并改成你的随机串；.env 已被 .gitignore，不入库。
# 关：本机开发可设 AUTH_ENABLED=false 免 Token。
AUTH_ENABLED=true

# 使用侧 Token（给前端大屏）——调 /api/value /records /series 用
API_TOKEN_APP=请改成随机串-app-xxxxxxxx

# 运维侧 Token（给运维）——调 /api/keys /api/reload 用（权限更高，也能调使用侧）
API_TOKEN_OPS=请改成随机串-ops-yyyyyyyy

# CORS 允许的前端来源（逗号分隔）；* 表示全部（演示可用，生产建议写具体域名）
# 例：CORS_ORIGINS=http://localhost:5173,https://大屏域名
CORS_ORIGINS=*

# 业务时区：决定"当前时刻"取数、网格对齐、累计起点按哪个时区理解。
# 缺省 Asia/Shanghai（北京时间）。容器默认 UTC，不设此项会导致取数时刻差 8 小时。
APP_TZ=Asia/Shanghai
